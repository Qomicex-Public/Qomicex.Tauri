{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qomicex-launcher",
  "version": "0.1.1",
  "identifier": "com.tauri-app.qomicex-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Qomicex Launcher",
        "width": 1140,
        "height": 790,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5000 ws://localhost:5000; img-src 'self' asset: http://localhost:5000 data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; media-src 'self' asset:"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0"
        ]
      },
      "rpm": {
        "depends": [
          "libwebkit2gtk-4.1-0"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnRydGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1RjFGQUNEOTY5MzgyMUQKUldRZGdwT1d6ZnJ4VlRUQWZJMWlJa0pGbjdJU1NPOTUrek1FbWFtdlU4dDdKT0V0NE9adzFLMGMK",
      "endpoints": [
        "https://github.com/Qomicex-Public/Qomicex.Tauri/releases/latest/download/latest.json"
      ]
    }
  }
}
