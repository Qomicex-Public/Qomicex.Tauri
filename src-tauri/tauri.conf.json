{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qomicex-launcher",
  "version": "0.1.0",
  "identifier": "com.tauri-app.qomicex-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Qomicex Launcher",
        "width": 1140,
        "height": 790,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0"
        ]
      },
      "rpm": {
        "depends": [
          "libwebkit2gtk-4.1-0"
        ]
      }
    }
  }
}
