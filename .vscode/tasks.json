{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-backend",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/src-backend/Qomicex.Launcher.Backend.Neo/Qomicex.Launcher.Backend.Neo.csproj",
				"--configuration",
				"Debug"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		},
		{
			"label": "build-backend-license",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/src-backend/Qomicex.Launcher.Backend.Neo/Qomicex.Launcher.Backend.Neo.csproj",
				"--configuration",
				"Debug",
				"-p:LicenseRequired=true"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		}
	]
}
