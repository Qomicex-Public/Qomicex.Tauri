{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "启动 Tauri",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "tauri",
                "dev"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
            }
        },
        {
            "name": "启动 ASP.NET Core",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-backend",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src-backend/Qomicex.Launcher.Backend.Neo/Qomicex.Launcher.Backend.Neo.csproj",
                "--",
                "--urls=http://localhost:5000"
            ],
            "cwd": "${workspaceFolder}/src-backend",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "启动 ASP.NET Core (许可证验证)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-backend-license",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src-backend/Qomicex.Launcher.Backend.Neo/Qomicex.Launcher.Backend.Neo.csproj",
                "-p:LicenseRequired=true",
                "--",
                "--urls=http://localhost:5000"
            ],
            "cwd": "${workspaceFolder}/src-backend",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ],
    "compounds": [
        {
            "name": "启动 Qomicex.Tauri",
            "configurations": [
                "启动 ASP.NET Core",
                "启动 Tauri"
            ],
            "stopAll": true
        },
        {
            "name": "启动 Qomicex.Tauri (许可证验证)",
            "configurations": [
                "启动 ASP.NET Core (许可证验证)",
                "启动 Tauri"
            ],
            "stopAll": true
        }
    ]
}
