+            if (proc == null) return "unknown";
+            var output = proc.StandardOutput.ReadToEnd();
+            proc.WaitForExit(3000);
+            var token = output.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
