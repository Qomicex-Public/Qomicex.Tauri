+    }
+
+    private PlayerIconMap ExchangeIcons(PlayerIconUpload upload)
+    {
+        lock (_iconLock)
+        {
+            if (!string.IsNullOrEmpty(upload.MachineId) && !string.IsNullOrEmpty(upload.IconBase64))
