{
  "version": "1.0.0",
  "lastUpdated": "2026-02-08",
  "patterns": [
    {
      "id": "out-of-memory-heap",
      "category": "Memory",
      "severity": "Critical",
      "i18n": {
        "zh": { "name": "Java堆内存不足", "description": "游戏分配的堆内存不足导致崩溃" },
        "en": { "name": "Java Heap Space Out of Memory", "description": "Game crashed due to insufficient heap memory allocation" }
      },
      "regexPatterns": [
        "java\\.lang\\.OutOfMemoryError: Java heap space",
        "java\\.lang\\.OutOfMemoryError: GC overhead limit exceeded"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "建议将最大内存分配增加到至少 {recommendedMemory}MB（当前可能过低）",
          "actionType": "IncreaseMemory",
          "parameters": { "recommendedMemory": 4096 }
        },
        {
          "priority": 2,
          "description": "如果内存已设置足够，尝试添加JVM参数：-XX:+UseG1GC -XX:MaxGCPauseMillis=200",
          "actionType": "AddJvmArgs"
        },
        {
          "priority": 3,
          "description": "关闭其他占用内存的程序后重试",
          "actionType": "CloseOtherApps"
        }
      ]
    },
    {
      "id": "out-of-memory-metaspace",
      "category": "Memory",
      "severity": "Critical",
      "i18n": {
        "zh": { "name": "Metaspace内存不足", "description": "类元数据空间不足，通常由过多Mod导致" },
        "en": { "name": "Metaspace Out of Memory", "description": "Class metadata space exhausted, usually caused by too many mods" }
      },
      "regexPatterns": [
        "java\\.lang\\.OutOfMemoryError: Metaspace",
        "java\\.lang\\.OutOfMemoryError: CompressedClassSpace"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "添加JVM参数增加Metaspace大小：-XX:MaxMetaspaceSize=512M",
          "actionType": "AddJvmArgs"
        },
        {
          "priority": 2,
          "description": "考虑减少同时加载的Mod数量",
          "actionType": "ReduceMods"
        }
      ]
    },
    {
      "id": "mod-duplicate",
      "category": "ModConflict",
      "severity": "Error",
      "i18n": {
        "zh": { "name": "Mod重复", "description": "检测到重复的Mod文件" },
        "en": { "name": "Duplicate Mod", "description": "Duplicate mod files detected" }
      },
      "regexPatterns": [
        "Found a duplicate mod (?<modId>[^\\s]+)",
        "Mod (?<modId>\\S+) has been loaded twice",
        "Duplicate Mods:\\s*\\{(?<modId>[^}]+)\\}"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "删除重复的Mod文件：{modId}，保留最新版本",
          "actionType": "RemoveDuplicateMod"
        }
      ]
    },
    {
      "id": "missing-dependency",
      "category": "ModConflict",
      "severity": "Error",
      "i18n": {
        "zh": { "name": "缺少依赖Mod", "description": "Mod需要其他Mod作为依赖但未找到" },
        "en": { "name": "Missing Dependency", "description": "Mod requires another mod as dependency" }
      },
      "regexPatterns": [
        "模组.*\\((?<modA>[^\\)]+)\\).*需要.*?(?<modB>architectury|fabric|forge|quilt).*?(?<version>\\d+\\.\\d+\\.\\d+)",
        "Mod \\((?<modA>[^)]+)\\).*requires.*?(?<modB>\\w+).*?(?<version>\\d+\\.\\d+\\.\\d+)",
        "MissingModsException: Mod \\{(?<modA>[^}]+)\\} requires \\{(?<modB>[^}]+)\\}",
        "Could not find required mod: '(?<modB>[^']+)'",
        "depends (?<modB>\\S+) @ \\[(?<version>[\\d.]+)"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "安装缺失的依赖Mod：{modB} 版本 {version} 或更高版本",
          "actionType": "InstallMod"
        },
        {
          "priority": 2,
          "description": "如果已安装该Mod，检查版本是否满足要求（需要 {version} 或更高）",
          "actionType": "CheckModVersion"
        }
      ]
    },
    {
      "id": "mod-version-conflict",
      "category": "ModConflict",
      "severity": "Error",
      "i18n": {
        "zh": { "name": "Mod版本冲突", "description": "Mod之间存在版本不兼容" },
        "en": { "name": "Mod Version Conflict", "description": "Incompatible mod versions" }
      },
      "regexPatterns": [
        "(?<modA>\\S+) is incompatible with (?<modB>\\S+)",
        "Conflicting mods found: (?<modA>[^,]+), (?<modB>[^\\s]+)"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "Mod {modA} 与 {modB} 存在冲突，请移除其中一个",
          "actionType": "RemoveConflictingMod"
        },
        {
          "priority": 2,
          "description": "尝试寻找兼容的两个Mod版本",
          "actionType": "FindCompatibleVersion"
        }
      ]
    },
    {
      "id": "incompatible-mod-set",
      "category": "ModConflict",
      "severity": "Error",
      "i18n": {
        "zh": { "name": "Mod集合不兼容", "description": "Mod之间存在不兼容，无法确定具体是哪个Mod" },
        "en": { "name": "Incompatible Mod Set", "description": "Mods are incompatible, specific conflicting mods unknown" }
      },
      "regexPatterns": [
        "Incompatible mod set!"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "检查完整的错误日志，找出具体冲突的Mod",
          "actionType": "ReviewFullLog"
        },
        {
          "priority": 2,
          "description": "尝试逐个移除最近添加的Mod来排查问题",
          "actionType": "BinarySearchMods"
        }
      ]
    },
    {
      "id": "java-version-too-old",
      "category": "JavaRelated",
      "severity": "Critical",
      "i18n": {
        "zh": { "name": "Java版本过旧", "description": "当前Java版本无法满足游戏或Mod要求" },
        "en": { "name": "Java Version Too Old", "description": "Current Java version too old for game or mods" }
      },
      "regexPatterns": [
        "class file version (?<major>\\d+)\\.(?<minor>\\d+)",
        "Unsupported class file major version (?<version>\\d+)",
        "has been compiled by a more recent version of the Java Runtime",
        "(?<class>\\S+)\\.class: version (?<version>\\d+)\\.\\d+"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "当前Java版本过旧，建议升级到Java {recommendedJava} 或更高版本",
          "actionType": "UpgradeJava",
          "parameters": { "recommendedJava": "17" }
        }
      ]
    },
    {
      "id": "java-version-too-new",
      "category": "JavaRelated",
      "severity": "Critical",
      "i18n": {
        "zh": { "name": "Java版本过新", "description": "当前Java版本过高，旧版游戏不支持" },
        "en": { "name": "Java Version Too New", "description": "Current Java version too new for old game version" }
      },
      "regexPatterns": [
        "Java version (?<version>\\d+) is not supported",
        "Unsupported Java version",
        "does not support Java (?<version>\\d+)"
      ],
      "solutions": [
        {
          "priority": 1,
          "description": "当前Java版本过高，建议使用Java {recommendedJava}",
          "actionType": "DowngradeJava",
          "parameters": { "recommendedJava": "8" }
        }
      ]
    },
    {
      "id": "missing-natives",
      "category": "Resource",
      "severity": "Error",
      "i18n": {
        "zh": { "name": "缺少本地库文件", "description": "无法找到必要的本地库文件（.dll/.so/.dylib）" },
        "en": { "name": "Missing Native Libraries", "description": "Required native libraries not found" }
      },
      "regexPatterns": [
